<?php
/**
 * ElielWeb ProductConfigurator - Canvas Wire Color Compositor
 */

$option           = $block->getData('option');
$product          = $block->getData('product');
$optionsViewModel = $block->getData('options_view_model');

$optionId    = (int)$option->getOptionId();
$colorsData  = $optionsViewModel->getWireColorsWithHex($option);

$goldColor  = $product->getData('gold_color') ?? 'or-blanc';
$goldSlug   = strtolower(str_replace([' ', '_', "'"], ['-', '-', ''], (string)$goldColor));
$goldMapping = [
    'or-blanc'    => 'or-blanc',
    'or-jaune'    => 'or-jaune',
    'or-rose'     => 'or-rose',
    'or-noir'     => 'or-noir',
    'white-gold'  => 'or-blanc',
    'yellow-gold' => 'or-jaune',
    'pink-gold'   => 'or-rose',
    'black-gold'  => 'or-noir',
];
$goldFile = $goldMapping[$goldSlug] ?? 'or-blanc';

$baseUrl     = $block->getBaseUrl();
$wireMaskUrl = $baseUrl . 'pub/media/configurator/wire-masks/1_B-base_gris.png';
$goldUrl     = $baseUrl . 'pub/media/configurator/gold/' . $goldFile . '.png';

$colorsJson = json_encode(array_map(fn($c) => [
    'id'    => $c['id'],
    'name'  => $c['name'],
    'hex'   => $c['hex'],
    'price' => $c['price'],
], $colorsData));
?>

<div class="wire-configurator"
     x-data="wireConfigurator(<?= $escaper->escapeHtmlAttr($colorsJson) ?>, <?= $optionId ?>)"
     x-init="init()">

    <input type="hidden"
           :name="'options[<?= $optionId ?>]'"
           x-model="selectedValueId"
           <?= $option->getIsRequire() ? 'required' : '' ?>>

    <!-- Canvas -->
    <div class="wire-canvas-wrap">
        <canvas x-ref="canvas" class="wire-canvas"></canvas>
        <div class="wire-canvas-loader" x-show="!ready">
            <span><?= $escaper->escapeHtml(__('Chargement...')) ?></span>
        </div>
    </div>

    <!-- Couleur sélectionnée -->
    <div class="wire-selected-label" x-show="selectedName" x-cloak>
        <span class="wire-dot" :style="'background:' + selectedHex"></span>
        <span x-text="selectedName"></span>
    </div>

    <!-- Preview 5 swatches + bouton modal -->
    <div class="wire-preview-row">
        <template x-for="color in previewColors" :key="color.id">
            <div class="wire-preview-swatch"
                 :style="'background:' + color.hex"
                 :class="{ 'active': selectedValueId == color.id }"
                 :title="color.name"
                 @click="selectColor(color)">
            </div>
        </template>
        <button type="button" class="wire-more-btn"
                @click="isModalOpen = true"
                x-show="colors.length > 5">
            +<span x-text="colors.length - 5"></span>
        </button>
    </div>

    <!-- Overlay modal -->
    <div class="wire-modal-overlay"
         x-show="isModalOpen"
         x-transition.opacity
         @click="isModalOpen = false"
         style="display:none;"></div>

    <!-- Modal grille -->
    <div class="wire-modal"
         x-show="isModalOpen"
         x-transition
         @click.away="isModalOpen = false"
         style="display:none;">
        <div class="wire-modal-header">
            <h3><?= $escaper->escapeHtml(__('Choisissez votre couleur de fil')) ?></h3>
            <button type="button" @click="isModalOpen = false" class="wire-modal-close">✕</button>
        </div>
        <div class="wire-modal-grid">
            <template x-for="color in colors" :key="color.id">
                <div class="wire-color-card"
                     :class="{ 'selected': selectedValueId == color.id }"
                     @click="selectColor(color); isModalOpen = false">
                    <div class="wire-color-circle" :style="'background:' + color.hex"></div>
                    <span class="wire-color-label" x-text="color.name"></span>
                </div>
            </template>
        </div>
    </div>
</div>

<script>
function wireConfigurator(colors, optionId) {
    return {
        colors: colors,
        previewColors: colors.slice(0, 5),
        selectedValueId: null,
        selectedName: '',
        selectedHex: '',
        isModalOpen: false,
        ready: false,
        wireImg: null,
        goldImg: null,

        init() {
            this.loadImages();
        },

        loadImages() {
            let loaded = 0;
            const onLoad = () => {
                loaded++;
                if (loaded === 2) { this.ready = true; this.render(); }
            };
            this.wireImg = new Image(); this.wireImg.crossOrigin = 'anonymous';
            this.goldImg = new Image(); this.goldImg.crossOrigin = 'anonymous';
            this.wireImg.onload = onLoad;
            this.goldImg.onload = onLoad;
            this.wireImg.src = '<?= $escaper->escapeJs($wireMaskUrl) ?>';
            this.goldImg.src = '<?= $escaper->escapeJs($goldUrl) ?>';
        },

        hexToRgb(hex) {
            return {
                r: parseInt(hex.slice(1,3), 16),
                g: parseInt(hex.slice(3,5), 16),
                b: parseInt(hex.slice(5,7), 16)
            };
        },

        colorizeWire(img, hex) {
            const canvas = this.$refs.canvas;
            const w = canvas.width, h = canvas.height;
            const rgb = this.hexToRgb(hex);
            const off = document.createElement('canvas');
            off.width = w; off.height = h;
            const ctx = off.getContext('2d');
            ctx.drawImage(img, 0, 0, w, h);
            const imageData = ctx.getImageData(0, 0, w, h);
            const d = imageData.data;
            for (let i = 0; i < d.length; i += 4) {
                const r = d[i], g = d[i+1], b = d[i+2], a = d[i+3];
                if (a < 10 || (r > 245 && g > 245 && b > 245)) { d[i+3] = 0; continue; }
                const gray = (r + g + b) / (3 * 255);
                const dark = 1 - gray;
                d[i]   = Math.round(rgb.r * gray + rgb.r * dark * 0.5);
                d[i+1] = Math.round(rgb.g * gray + rgb.g * dark * 0.5);
                d[i+2] = Math.round(rgb.b * gray + rgb.b * dark * 0.5);
                d[i+3] = Math.min(255, Math.round(dark * 300));
            }
            ctx.putImageData(imageData, 0, 0);
            return off;
        },

        render() {
            const canvas = this.$refs.canvas;
            const ctx = canvas.getContext('2d');
            const w = this.wireImg.naturalWidth || 920;
            const h = this.wireImg.naturalHeight || 920;
            canvas.width = w; canvas.height = h;
            ctx.clearRect(0, 0, w, h);
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(0, 0, w, h);
            if (this.selectedHex) {
                ctx.drawImage(this.colorizeWire(this.wireImg, this.selectedHex), 0, 0, w, h);
            } else {
                ctx.drawImage(this.wireImg, 0, 0, w, h);
            }
            ctx.drawImage(this.goldImg, 0, 0, w, h);
        },

        selectColor(color) {
            this.selectedValueId = color.id;
            this.selectedName    = color.name;
            this.selectedHex     = color.hex;
            this.render();
            this.$dispatch('option-selected', {
                optionId: optionId,
                valueId: color.id,
                price: color.price
            });
        }
    }
}
</script>

